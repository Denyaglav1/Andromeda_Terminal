{
  "name": "@andromeda/design-system",
  "version": "0.1.0",
  "description": "Andromeda Design System — React components, CSS tokens, ECharts & Mantine themes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@mantine/core": "^8.0.0",
    "@mantine/hooks": "^8.0.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.0",
    "lucide-react": ">=0.400.0"
  },
  "peerDependenciesMeta": {
    "echarts": { "optional": true },
    "echarts-for-react": { "optional": true },
    "@mantine/core": { "optional": true },
    "@mantine/hooks": { "optional": true },
    "lucide-react": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@mantine/core": "^8.3.0",
    "@mantine/hooks": "^8.3.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.0",
    "lucide-react": "^0.487.0",
    "typescript": "^5.5.0",
    "vite": "^6.3.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "keywords": [
    "andromeda",
    "design-system",
    "react",
    "mantine",
    "echarts",
    "financial",
    "dashboard"
  ],
  "license": "MIT"
}